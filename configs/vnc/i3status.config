general {
        colors = true
        interval = 5
        output_format = "i3bar"
        color_good = "#a3be8c"
        color_degraded = "#ebcb8b"
        color_bad = "#bf616a"
        separator = "  "
}

order += "ethernet _first_"
order += "disk /"
order += "load"
order += "memory"
order += "tztime local"

ethernet _first_ {
        format_up = " %ip"
        format_down = " down"
}

disk "/" {
        format = " %avail"
}

load {
        format = " %1min"
}

memory {
        format = " %used | %available"
        threshold_degraded = "1G"
        format_degraded = " < %available"
}

tztime local {
        format = " %a %d %b %I:%M %p"
}
