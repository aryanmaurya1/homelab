general {
        colors = true
        interval = 5
}

order += "ethernet _first_"
order += "disk /"
order += "load"
order += "memory"
order += "tztime local"

ethernet _first_ {
        format_up = "´éČ %ip (%speed)"
        format_down = "´éČ down"
}

disk "/" {
        format = "´éá %avail"
}

load {
        format = "´âĄ %1min"
}

memory {
        format = "´őŤ %used | %available"
        threshold_degraded = "1G"
        format_degraded = "´őŤ < %available"
}

tztime local {
        format = "´ÇŚ %Y-%m-%d %I:%M %p"
}
