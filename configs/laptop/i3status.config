general {
        colors = true
        interval = 5
        output_format = "i3bar"
        color_good = "#a3be8c"
        color_degraded = "#ebcb8b"
        color_bad = "#bf616a"
        separator = " о‚і "
}

order += "wireless _first_"
order += "volume master"
order += "battery all"
order += "cpu_temperature 0"
order += "disk /"
order += "memory"
order += "tztime local"

wireless _first_ {
        format_up = "п‡« %essid %ip"
        format_down = "п‡« down"
}

volume master {
        format = "пЂЁ %volume"
        format_muted = "пЂ¦ muted"
        device = "pulse"
}

battery all {
        format = "п‰Ђ %percentage"
        low_threshold = 15
        threshold_type = "percentage"
        integer_battery_capacity = true
}

cpu_temperature 0 {
        format = "п‹‰ %degreesВ°C"
        max_threshold = 75
}

disk "/" {
        format = "п‚  %avail"
}

memory {
        format = "п‹› %used | %available"
        threshold_degraded = "1G"
        format_degraded = "п‹› < %available"
}

tztime local {
        format = "пЂ— %a %d %b %I:%M %p"
}
