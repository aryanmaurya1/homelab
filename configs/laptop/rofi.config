configuration {
  modi:               "drun,run";
  show-icons:         false;
  display-drun:       "   Apps";
  display-run:        "   Run";
  drun-display-format: "{name}";
  font:               "JetBrainsMonoNL Nerd Font Mono 10";
}

* {
  bg0:     #2e3440;
  bg1:     #3b4252;
  bg2:     #434c5e;
  fg0:     #d8dee9;
  fg1:     #e5e9f0;
  fg2:     #eceff4;
  blue:    #88c0d0;
  red:     #bf616a;
  green:   #a3be8c;
  orange:  #d08770;
  yellow:  #ebcb8b;
  purple:  #b48ead;
  cyan:    #8fbcbb;
  gray:    #4c566a;

  background-color:   transparent;
  text-color:         @fg0;
}

window {
  background-color:   @bg0;
  border-color:       @blue;
  border:            2px;
  width:             400px;
  location:          center;
  anchor:            center;
  padding:           8px;
}

inputbar {
  background-color:   @bg1;
  text-color:         @fg0;
  padding:           6px 12px;
  border-radius:     6;
  children:          [ "entry", "dummy" ];
}

entry {
  placeholder:        "Search…";
  text-color:         @fg0;
  margin:             0 6px;
}

dummy {
  width: 0;
}

listview {
  background-color:   transparent;
  columns:            2;
  lines:              6;
  cycle:              true;
  dynamic:            true;
  spacing:            4px;
  padding:            4px 0 0 0;
}

element {
  background-color:   transparent;
  text-color:         @fg1;
  padding:            6px 10px;
  border-radius:      6;
}

element selected {
  background-color:   @blue;
  text-color:         @bg0;
}

element normal.urgent {
  background-color:   transparent;
  text-color:         @red;
}

element normal.active {
  background-color:   transparent;
  text-color:         @green;
}

element selected.urgent {
  background-color:   @red;
  text-color:         @fg2;
}

element selected.active {
  background-color:   @green;
  text-color:         @bg0;
}

element-icon {
  background-color:   transparent;
  padding:            0 2px;
  size:               24px;
}

element-text {
  background-color:   transparent;
  text-color:         inherit;
  vertical-align:     0.5;
  margin:             0 4px;
}

scrollbar {
  handle-color:       @gray;
  width:              6px;
}

message {
  background-color:   @bg1;
  text-color:         @fg0;
  padding:            6px;
  border-radius:      6;
}

error-message {
  background-color:   @bg1;
  text-color:         @red;
  padding:            12px;
  border-radius:      6;
}
